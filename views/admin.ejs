<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <title>طلبات هليل | لوحة الإدارة</title>
  <link rel="stylesheet" href="/admin.css">
</head>
<body class="dashboard-page auth-pending" data-page="admin">
  <header class="dashboard-header">
    <div class="dashboard-container header-content">
      <a class="dashboard-brand" href="/admin" aria-label="لوحة إدارة هليل">
        <span class="brand-mark brand-mark-small"><img src="/images/logo.png" alt=""></span>
        <span><strong>هليل</strong><small>إدارة الطلبات</small></span>
      </a>

      <div class="admin-account">
        <span class="account-copy"><small>مسجل الدخول</small><strong id="adminEmail"><%= adminEmail %></strong></span>
        <form id="logoutForm" action="/logout" method="post">
          <button class="logout-button" type="submit">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4m7 14l5-5-5-5m5 5H9"/></svg>
            <span>تسجيل الخروج</span>
          </button>
        </form>
      </div>
    </div>
  </header>

  <main class="dashboard-container dashboard-main" id="dashboardMain" aria-busy="true">
    <section class="page-heading">
      <div>
        <span class="eyebrow">نظرة عامة</span>
        <h1>طلبات العملاء</h1>
        <p>تابع طلبات التواصل والمهتمين بنمو العلامة التجارية والفرنشايز.</p>
      </div>
      <button class="refresh-button" id="refreshRequests" type="button">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M20 11a8.1 8.1 0 00-15.5-2M4 4v5h5m-5 4a8.1 8.1 0 0015.5 2M20 20v-5h-5"/></svg>
        تحديث البيانات
      </button>
    </section>

    <div id="adminLoadError" class="alert alert-error" role="alert" hidden></div>

    <section class="stats-grid" aria-label="إحصائيات الطلبات">
      <article class="stat-card">
        <span class="stat-icon stat-icon-red"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zm13 10v-2a4 4 0 00-3-3.87m-2-11.96a4 4 0 010 7.75"/></svg></span>
        <div><span>إجمالي الطلبات</span><strong id="statTotal">—</strong></div>
      </article>
      <article class="stat-card">
        <span class="stat-icon stat-icon-violet"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M3 3v18h18M7 16l4-5 3 3 5-7"/></svg></span>
        <div><span>نمو العلامة</span><strong id="statGrowth">—</strong></div>
      </article>
      <article class="stat-card">
        <span class="stat-icon stat-icon-amber"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2zm6 13V12h6v10"/></svg></span>
        <div><span>طلبات الفرنشايز</span><strong id="statFranchise">—</strong></div>
      </article>
      <article class="stat-card">
        <span class="stat-icon stat-icon-blue"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M21 10c0 7-9 12-9 12S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
        <div><span>المدن</span><strong id="statCities">—</strong></div>
      </article>
    </section>

    <section class="requests-panel" aria-labelledby="requests-title">
      <div class="panel-header">
        <div><h2 id="requests-title">قائمة الطلبات</h2><p><span id="visibleCount">0</span> طلب ظاهر</p></div>
        <div class="search-control">
          <svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <label class="sr-only" for="requestSearch">البحث في الطلبات</label>
          <input id="requestSearch" type="search" placeholder="ابحث بالاسم أو الرقم أو المدينة" disabled>
          <button id="clearSearch" class="clear-search" type="button" aria-label="مسح البحث" hidden>
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>
      </div>

      <div id="requestsLoading" class="empty-state">
        <span class="loading-spinner" aria-hidden="true"></span>
        <h3>جاري تحميل الطلبات</h3>
      </div>

      <div id="requestsEmpty" class="empty-state" hidden>
        <span><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M21 15V6a2 2 0 00-2-2H5a2 2 0 00-2 2v9m18 0l-3.5 4H6.5L3 15m18 0h-5l-1 2H9l-1-2H3"/></svg></span>
        <h3>لا توجد طلبات حتى الآن</h3>
        <p>ستظهر الطلبات الجديدة هنا فور إرسالها من الموقع.</p>
      </div>

      <div class="table-wrap" id="requestsTableWrap" hidden>
        <table class="requests-table">
          <thead><tr><th scope="col">العميل</th><th scope="col">رقم التواصل</th><th scope="col">المدينة</th><th scope="col">الاهتمامات</th><th scope="col">تاريخ الإرسال</th></tr></thead>
          <tbody id="requestsBody"></tbody>
        </table>
      </div>
      <div id="noSearchResults" class="no-search-results" hidden>لا توجد طلبات مطابقة لعبارة البحث.</div>
    </section>
  </main>

  <script src="/firebase-config.js"></script>
  <script type="module" src="/firebase-client.bundle.js"></script>
</body>
</html>
