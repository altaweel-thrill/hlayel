<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <title>تسجيل دخول الإدارة | هليل</title>
  <link rel="stylesheet" href="/admin.css">
</head>
<body class="login-page" data-page="login">
  <main class="login-shell">
    <section class="login-card" aria-labelledby="login-title">
      <div class="login-brand">
        <span class="brand-mark"><img src="/images/logo.png" alt="هليل"></span>
        <div>
          <span class="eyebrow">لوحة الإدارة</span>
          <h1 id="login-title">مرحبًا بعودتك</h1>
        </div>
      </div>

      <p class="login-intro">سجّل الدخول لمراجعة طلبات التواصل والفرنشايز.</p>

      <div id="loginError" class="alert alert-error" role="alert" <%= error ? '' : 'hidden' %>><%= error || '' %></div>

      <form class="login-form" action="/sign" method="post">
        <div class="field-group">
          <label for="email">البريد الإلكتروني</label>
          <input id="email" name="email" type="email" autocomplete="username" required autofocus placeholder="admin@example.com">
        </div>

        <div class="field-group">
          <label for="password">كلمة المرور</label>
          <input id="password" name="password" type="password" autocomplete="current-password" required placeholder="أدخل كلمة المرور">
        </div>

        <button class="primary-button" type="submit">
          <span>تسجيل الدخول</span>
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M10 17l5-5-5-5M15 12H3m12-9h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/></svg>
        </button>
      </form>

      <a class="back-link" href="/">العودة إلى الموقع</a>
    </section>
  </main>
  <script src="/firebase-config.js"></script>
  <script type="module" src="/firebase-client.bundle.js"></script>
</body>
</html>
