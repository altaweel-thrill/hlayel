<% const copy = {
  ar: { title: 'تم إرسال الطلب بنجاح', message: 'شكرًا لك، سيتواصل معك فريقنا قريبًا.' },
  en: { title: 'Your request was sent', message: 'Thank you. Our team will contact you soon.' },
  de: { title: 'Ihre Anfrage wurde gesendet', message: 'Vielen Dank. Unser Team wird Sie bald kontaktieren.' }
}; const current = copy[language] || copy.ar; %>
<!DOCTYPE html>
<html lang="<%= language %>" dir="<%= language === 'ar' ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= current.title %> | هليل</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main class="contanir submit-page">
    <img class="logo" src="/images/logo.png" alt="هليل">
    <section class="success-card">
      <span class="success-icon" aria-hidden="true">✓</span>
      <h1><%= current.title %></h1>
      <p><%= current.message %></p>
      <a class="home-link" href="/">العودة إلى الموقع</a>
    </section>
    <a class="whatsapp-link" href="https://wa.me/966510101060" aria-label="التواصل عبر واتساب">
      <img width="72" src="/images/whatsapp.png" alt="">
    </a>
    <img class="idimg" src="/images/id.png" alt="">
  </main>
</body>
</html>
