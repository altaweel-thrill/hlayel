rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /requests/{requestId} {
      allow create: if request.resource.data.keys().hasAll([
          'name',
          'mobile',
          'city',
          'brandGrowth',
          'franchise',
          'language',
          'submittedAt',
          'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'name',
          'mobile',
          'city',
          'brandGrowth',
          'franchise',
          'language',
          'submittedAt',
          'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 100
        && request.resource.data.mobile is string
        && request.resource.data.mobile.size() >= 7
        && request.resource.data.mobile.size() <= 30
        && request.resource.data.city is string
        && request.resource.data.city.size() <= 100
        && request.resource.data.brandGrowth is bool
        && request.resource.data.franchise is bool
        && request.resource.data.language in ['ar', 'en', 'de']
        && request.resource.data.submittedAt is string
        && request.resource.data.submittedAt.size() <= 40
        && request.resource.data.createdAt == request.time;

      // Only the Firebase Authentication admin account may read customer data.
      allow read: if request.auth != null
        && request.auth.token.email == 'altaweel@thrillagency.net';
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
